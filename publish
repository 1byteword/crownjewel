def _inject_post_meta(content, date):
    """Insert <time> immediately after the <h1> title in rendered post content.

    parse_markdown() emits the full content; publish_post() wraps it with
    "<h1>{title}</h1>\\n{html_content}". We slip the <time> in after the h1
    so the date sits with the title as the article meta header.
    """
    time_tag = f'    <time>{date}</time>'
    return re.sub(
        r'(<h1>[^<]*</h1>)',
        lambda m: f'    {m.group(1)}\n{time_tag}',
        content,
        count=1,
    )

def publish_post(md_file, date=None):
    """Publish markdown post as standalone HTML page"""

    # Read markdown
    with open(md_file, 'r', encoding='utf-8') as f:
        md_content = f.read()

    # Extract title and excerpt
    title = extract_title(md_content)
    excerpt = extract_excerpt(md_content)

    # Get date
    if not date:
        # Try to extract from filename (YYYY-MM-DD-title.md)
        match = re.search(r'(\d{4}-\d{2}-\d{2})', md_file)
        if match:
            date = match.group(1)
        else:
            date = datetime.now().strftime('%Y-%m-%d')

    date_formatted = date.replace('-', '.')

    # Slug: strip the YYYY-MM-DD- prefix so the URL stays stable even if
    # the source filename conventions change. The date lives on the page
    # and in the filesystem sort key; it doesn't need to be in the URL.
    slug = re.sub(r'^\d{4}-\d{2}-\d{2}-', '', Path(md_file).stem)

    # Handle images
    md_content = handle_images(md_content, md_file)

    # Remove title from content (it'll be in <h1>)
    md_content_no_title = re.sub(r'^# .+$\n?', '', md_content, count=1, flags=re.MULTILINE)

    # Convert to HTML
    html_content = parse_markdown(md_content_no_title)

    # Add title as h1
    full_content = f'<h1>{title}</h1>\n{html_content}'

    # Create post HTML file
    writing_dir = Path('writing')
    writing_dir.mkdir(exist_ok=True)

    post_file = writing_dir / f'{slug}.html'
    post_html = create_post_html(title, date_formatted, full_content)

    with open(post_file, 'w', encoding='utf-8') as f:
        f.write(post_html)

    # Update writing/index.html: dedupe by slug, insert, then sort
    # newest-first by <time> so ordering is always chronological regardless
    # of what order posts were published in.
    writing_entry = (
        f'    <article>\n'
        f'      <time>{date_formatted}</time>\n'
        f'      <div>\n'
        f'        <h2><a href="/writing/{slug}">{title}</a></h2>\n'
        f'        <p>{excerpt}</p>\n'
        f'      </div>\n'
        f'    </article>\n'
    )

    if not _update_writing_index(slug, writing_entry):
        return False

    # Mirror the newest posts into the homepage's 03/writing block so the
    # landing page doesn't silently go stale when a new post ships.
    _update_homepage_latest()

    print(f"✓ Published: {title}")
    print(f"  Date: {date_formatted}")
    print(f"  URL: /writing/{slug}")
    print(f"\nNext steps:")
    print(f"  1. Review: open writing/{slug}.html  (or http://localhost:8000/writing/{slug} under `make dev`)")
    print(f"  2. Deploy: git push && make ship")

    return True


WRITING_INDEX = 'writing/index.html'


def _update_writing_index(slug, writing_entry):
    """Insert a post entry into writing/index.html between the POST_ENTRIES
    markers, removing any prior entry for the same slug (idempotent
    re-publish) and sorting by <time> descending.
    """
    start_marker = '<!-- POST_ENTRIES_START -->'
    end_marker = '<!-- POST_ENTRIES_END -->'

    with open(WRITING_INDEX, 'r', encoding='utf-8') as f:
        page = f.read()

    s = page.find(start_marker)
    e = page.find(end_marker)
    if s == -1 or e == -1 or e < s:
        print(f"❌ {WRITING_INDEX} is missing {start_marker} / {end_marker} markers")
        return False

    inner = page[s + len(start_marker):e]

    # Pull existing <article>…</article> blocks out of the region. Anything
    # else (stray whitespace) we drop on the floor when we rebuild.
    articles = re.findall(r'<article\b[\s\S]*?</article>', inner)

    # Drop any existing entry that links to this slug (idempotent re-publish).
    # Match on "/writing/<slug>" with a word boundary so we don't accidentally
    # prefix-match (e.g. /writing/foo must not match /writing/foo-bar).
    slug_href = f'/writing/{slug}"'
    articles = [a for a in articles if slug_href not in a]

    # Add the new one (entry already ends with a trailing newline).
    articles.append(writing_entry.rstrip('\n'))

    # Sort newest-first by the <time> value. Articles without a parseable
    # <time> sort to the bottom.
    def _sort_key(article_html):
        m = re.search(r'<time>([^<]+)</time>', article_html)
        return m.group(1) if m else ''

    articles.sort(key=_sort_key, reverse=True)

    rebuilt = '\n' + '\n\n'.join('    ' + a.lstrip() for a in articles) + '\n    '
    new_page = page[:s + len(start_marker)] + rebuilt + page[e:]

    with open(WRITING_INDEX, 'w', encoding='utf-8') as f:
        f.write(new_page)

    return True


# How many of the newest posts to surface in the homepage's writing section.
# The rest live one click away at /writing. Bump this knob if the list
# starts feeling sparse.
HOMEPAGE_LATEST_COUNT = 5


def _update_homepage_latest():
    """Rewrite the HOMEPAGE_LATEST_POST block in index.html to mirror the
    N newest posts from writing/index.html (already sorted newest-first there).
    Silent no-op if either page is missing the expected markers.
    """
    index_path = Path('index.html')
    writing_path = Path(WRITING_INDEX)
    if not index_path.exists() or not writing_path.exists():
        return

    writing_page = writing_path.read_text(encoding='utf-8')
    m = re.search(
        r'<!-- POST_ENTRIES_START -->([\s\S]*?)<!-- POST_ENTRIES_END -->',
        writing_page,
    )
    if not m:
        return

    articles = re.findall(r'<article\b[\s\S]*?</article>', m.group(1))
    if not articles:
        return

    blocks = []
    for article in articles[:HOMEPAGE_LATEST_COUNT]:
        title_m = re.search(r'<h2><a href="([^"]+)">([^<]+)</a></h2>', article)
        time_m = re.search(r'<time>([^<]+)</time>', article)
        dek_m = re.search(r'<p>([^<]+)</p>', article)
        if not (title_m and time_m and dek_m):
            continue
        href, title = title_m.group(1), title_m.group(2)
        # Homepage shows YYYY.MM (shorter), writing page shows YYYY.MM.DD.
        date_short = '.'.join(time_m.group(1).split('.')[:2])
        dek = dek_m.group(1)
        blocks.append(
            '        <div class="writing-item">\n'
            '          <div class="row">\n'
            f'            <div class="title"><a href="{href}">{title}</a></div>\n'
            f'            <div class="date">{date_short}</div>\n'
            '          </div>\n'
            f'          <div class="dek">{dek}</div>\n'
            '        </div>\n'
        )

    if not blocks:
        return

    rendered = ''.join(blocks)

    index_page = index_path.read_text(encoding='utf-8')
    new_index = re.sub(
        r'(<!-- HOMEPAGE_LATEST_POST_START -->)[\s\S]*?(<!-- HOMEPAGE_LATEST_POST_END -->)',
        lambda mm: f'{mm.group(1)}\n{rendered}        {mm.group(2)}',
        index_page,
        count=1,
    )
    if new_index != index_page:
        index_path.write_text(new_index, encoding='utf-8')

if __name__ == '__main__':
    if len(sys.argv) < 2:
        print("Usage: ./publish <markdown-file> [--date YYYY-MM-DD]")
        sys.exit(1)

    md_file = sys.argv[1]
    date = None

    if '--date' in sys.argv:
        date_idx = sys.argv.index('--date')
        if date_idx + 1 < len(sys.argv):
            date = sys.argv[date_idx + 1]

    if not os.path.exists(md_file):
        print(f"❌ File not found: {md_file}")
        sys.exit(1)

    publish_post(md_file, date)
