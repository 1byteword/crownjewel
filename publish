#!/usr/bin/env python3
"""
Publish a markdown post as a standalone HTML page

Usage:
  ./publish src/posts/2025-01-15-my-post.md

Creates:
  - writing/my-post.html (served at /writing/my-post -- date prefix in
    source filename is used for sort/organization, not routing)
  - Updates writing/index.html with a post list entry
  - Mirrors the N newest posts into the homepage's writing section

Markdown format:
  # Title

  First paragraph becomes the excerpt.

  Rest of content...

  ![alt text](image.jpg)  # Images auto-copied to /img
"""

import sys
import os
import re
from datetime import datetime
from pathlib import Path

def parse_markdown(md_content):
    """Convert markdown to simple HTML"""
    html = md_content

    # Headers
    html = re.sub(r'^# (.+)$', r'<h1>\1</h1>', html, flags=re.MULTILINE)
    html = re.sub(r'^## (.+)$', r'<h2>\1</h2>', html, flags=re.MULTILINE)
    html = re.sub(r'^### (.+)$', r'<h3>\1</h3>', html, flags=re.MULTILINE)

    # Bold and italic
    html = re.sub(r'\*\*(.+?)\*\*', r'<strong>\1</strong>', html)
    html = re.sub(r'\*(.+?)\*', r'<em>\1</em>', html)
    html = re.sub(r'__(.+?)__', r'<strong>\1</strong>', html)
    html = re.sub(r'_(.+?)_', r'<em>\1</em>', html)

    # Code blocks
    html = re.sub(r'```([^\n]*)\n(.*?)```', r'<pre><code>\2</code></pre>', html, flags=re.DOTALL)

    # Inline code
    html = re.sub(r'`(.+?)`', r'<code>\1</code>', html)

    # Links
    html = re.sub(r'\[([^\]]+)\]\(([^\)]+)\)', r'<a href="\2">\1</a>', html)

    # Images
    html = re.sub(r'!\[([^\]]*)\]\(([^\)]+)\)', r'<img src="\2" alt="\1">', html)

    # Lists - process line by line to group consecutive items
    lines = html.split('\n')
    in_list = False
    result_lines = []

    for line in lines:
        stripped = line.strip()
        if stripped.startswith('- '):
            if not in_list:
                result_lines.append('<ul>')
                in_list = True
            item = stripped[2:]
            result_lines.append(f'<li>{item}</li>')
        elif in_list and not stripped:
            # Blank line inside a bullet list -- don't close the list,
            # markdown allows space between items in the same list.
            continue
        else:
            if in_list:
                result_lines.append('</ul>')
                in_list = False
            result_lines.append(line)

    if in_list:
        result_lines.append('</ul>')

    html = '\n'.join(result_lines)

    # Paragraphs (lines separated by blank line)
    paragraphs = []
    current = []
    blank_count = 0

    for line in html.split('\n'):
        line = line.strip()
        if line:
            if line.startswith(('<h', '<img', '<ul', '<ol', '<li', '</ul', '</ol', '<pre')):
                if current:
                    p_text = ' '.join(current)
                    # Check if it's an attribution (italic only)
                    if p_text.startswith('<em>') and p_text.endswith('</em>') and p_text.count('<em>') == 1:
                        paragraphs.append('<p class="attribution">' + p_text + '</p>')
                    else:
                        # Add spacer class if multiple blank lines preceded this
                        p_class = ' class="spacer"' if blank_count > 1 else ''
                        paragraphs.append(f'<p{p_class}>' + p_text + '</p>')
                    current = []
                    blank_count = 0
                paragraphs.append(line)
            elif line == '</code></pre>':
                paragraphs.append(line)
            else:
                current.append(line)
        else:
            if current:
                p_text = ' '.join(current)
                # Check if it's an attribution (italic only)
                if p_text.startswith('<em>') and p_text.endswith('</em>') and p_text.count('<em>') == 1:
                    paragraphs.append('<p class="attribution">' + p_text + '</p>')
                else:
                    # Add spacer class if multiple blank lines preceded this
                    p_class = ' class="spacer"' if blank_count > 1 else ''
                    paragraphs.append(f'<p{p_class}>' + p_text + '</p>')
                current = []
                blank_count = 0
            blank_count += 1

    if current:
        p_text = ' '.join(current)
        if p_text.startswith('<em>') and p_text.endswith('</em>') and p_text.count('<em>') == 1:
            paragraphs.append('<p class="attribution">' + p_text + '</p>')
        else:
            paragraphs.append('<p>' + p_text + '</p>')

    return '\n'.join(paragraphs)

def extract_title(md_content):
    """Extract title from first # header"""
    match = re.search(r'^# (.+)$', md_content, re.MULTILINE)
    return match.group(1) if match else "Untitled"

def extract_excerpt(md_content):
    """Extract first paragraph after title as excerpt"""
    # Remove title
    content = re.sub(r'^# .+$', '', md_content, flags=re.MULTILINE)

    # Get first non-empty paragraph
    lines = []
    started = False
    for line in content.split('\n'):
        line = line.strip()
        if not line:
            if started:
                break
            continue
        if line.startswith(('#', '!', '-', '`')):
            if started:
                break
            continue
        started = True
        lines.append(line)

    excerpt = ' '.join(lines)
    # Truncate if too long
    if len(excerpt) > 200:
        excerpt = excerpt[:197] + '...'

    return excerpt if excerpt else "No description available."

def handle_images(md_content, md_file_path):
    """Copy images to /img and update paths"""
    img_dir = Path('img')
    img_dir.mkdir(exist_ok=True)

    md_dir = Path(md_file_path).parent

    # Find all image references
    images = re.findall(r'!\[[^\]]*\]\(([^\)]+)\)', md_content)

    for img_path in images:
        # Skip if already absolute or http
        if img_path.startswith(('http://', 'https://', '/')):
            continue

        # Copy image to /img
        src = md_dir / img_path
        if src.exists():
            dest = img_dir / src.name
            import shutil
            shutil.copy2(src, dest)

            # Rewrite to /img/ (relative) so the post HTML at
            # writing/<slug>.html finds it at ../img/<name>.
            md_content = md_content.replace(f']({img_path})', f'](../img/{src.name})')
            print(f"✓ Copied image: {src.name}")

    return md_content

