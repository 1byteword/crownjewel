def _inject_post_meta(content, date):
    """Insert <time> immediately after the <h1> title in rendered post content.

    parse_markdown() emits the full content; publish_post() wraps it with
    "<h1>{title}</h1>\\n{html_content}". We slip the <time> in after the h1
    so the date sits with the title as the article meta header.
    """
    time_tag = f'    <time>{date}</time>'
    return re.sub(
        r'(<h1>[^<]*</h1>)',
        lambda m: f'    {m.group(1)}\n{time_tag}',
        content,
        count=1,
    )

def publish_post(md_file, date=None):
    """Publish markdown post as standalone HTML page"""

    # Read markdown
    with open(md_file, 'r', encoding='utf-8') as f:
        md_content = f.read()

    # Extract title and excerpt
    title = extract_title(md_content)
    excerpt = extract_excerpt(md_content)

    # Get date
    if not date:
        # Try to extract from filename (YYYY-MM-DD-title.md)
        match = re.search(r'(\d{4}-\d{2}-\d{2})', md_file)
        if match:
            date = match.group(1)
        else:
            date = datetime.now().strftime('%Y-%m-%d')

    date_formatted = date.replace('-', '.')

    # Generate slug from filename
    slug = Path(md_file).stem  # e.g., "2025-01-16-my-post"

    # Handle images
    md_content = handle_images(md_content, md_file)

    # Remove title from content (it'll be in <h1>)
    md_content_no_title = re.sub(r'^# .+$\n?', '', md_content, count=1, flags=re.MULTILINE)

    # Convert to HTML
    html_content = parse_markdown(md_content_no_title)

    # Add title as h1
    full_content = f'<h1>{title}</h1>\n{html_content}'

    # Create post HTML file
    posts_dir = Path('posts')
    posts_dir.mkdir(exist_ok=True)

    post_file = posts_dir / f'{slug}.html'
    post_html = create_post_html(title, date_formatted, full_content)

    with open(post_file, 'w', encoding='utf-8') as f:
        f.write(post_html)

    # Update writing.html with post entry. The new writing.html structure
    # uses an explicit insertion marker so we don't have to depend on heading
    # text or class names that might change with future redesigns.
    writing_entry = f'''    <article>
      <time>{date_formatted}</time>
      <div>
        <h2><a href="/posts/{slug}.html">{title}</a></h2>
        <p>{excerpt}</p>
      </div>
    </article>
'''

    with open('writing.html', 'r', encoding='utf-8') as f:
        writing_page = f.read()

    marker = '<!-- POST_ENTRIES_START -->'
    idx = writing_page.find(marker)
    if idx == -1:
        print("❌ Could not find <!-- POST_ENTRIES_START --> marker in writing.html")
        return False

    insert_at = idx + len(marker)
    new_writing_page = writing_page[:insert_at] + '\n' + writing_entry + writing_page[insert_at:]

    # Write back
    with open('writing.html', 'w', encoding='utf-8') as f:
        f.write(new_writing_page)

    print(f"✓ Published: {title}")
    print(f"  Date: {date_formatted}")
    print(f"  URL: /posts/{slug}.html")
    print(f"\nNext steps:")
    print(f"  1. Review: open posts/{slug}.html in browser")
    print(f"  2. Deploy: make canary-push")

    return True

if __name__ == '__main__':
    if len(sys.argv) < 2:
        print("Usage: ./publish <markdown-file> [--date YYYY-MM-DD]")
        sys.exit(1)

    md_file = sys.argv[1]
    date = None

    if '--date' in sys.argv:
        date_idx = sys.argv.index('--date')
        if date_idx + 1 < len(sys.argv):
            date = sys.argv[date_idx + 1]

    if not os.path.exists(md_file):
        print(f"❌ File not found: {md_file}")
        sys.exit(1)

    publish_post(md_file, date)
